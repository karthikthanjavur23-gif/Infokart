# Your permanent or temporary Meta Graph API Access Token (from Meta Developer App)
META_ACCESS_TOKEN=your_access_token_here

# The WhatsApp Phone Number ID (from the WhatsApp section in your App)
PHONE_NUMBER_ID=your_phone_number_id_here

# A random string you define here and provide to Meta when setting up the Webhook
WEBHOOK_VERIFY_TOKEN=my_secure_verify_token

# Port for this local backend server
PORT=3001

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# WhatsApp Embedded Signup (Meta App Credentials)
# Get these from your Meta Developer Dashboard
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_CONFIG_ID=your_embedded_signup_config_id_here
